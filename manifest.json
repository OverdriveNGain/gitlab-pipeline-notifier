{
  "manifest_version": 3,
  "name": "GitLab Pipeline Notifier",
  "version": "1.0",
  "description": "Notifies you when a GitLab pipeline completes.",
  "permissions": [
    "notifications"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "notifications.js",
        "mr_reorder.js",
        "mr_floating_widget.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}